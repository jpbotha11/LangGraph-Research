# --- Observability Configuration ---
# Set the provider to "langsmith", "langfuse", or "none".
OBSERVABILITY_PROVIDER="none"

# Langsmith (https://smith.langchain.com/) - Required if PROVIDER is "langsmith"
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_ENDPOINT=
LANGCHAIN_PROJECT=

# Langfuse (https://langfuse.com/) - Required if PROVIDER is "langfuse"
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# --- Azure OpenAI Configuration ---
# Required for the research agent to function.
AZURE_OPENAI_ENDPOINT=
OPENAI_API_VERSION=
OPENAI_API_DEPLOYMENT_NAME=
OPENAI_API_KEY=

# --- Services Configuration ---
# Required for the research agent to function.
QDRANT_URL=
SEARX_URL=
BROWSER_WS_ENDPOINT=
